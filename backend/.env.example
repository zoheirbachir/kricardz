# Copy to .env on the server and fill in real values:  cp .env.example .env
# (Loaded automatically because `dotenv` is a dependency.)

# Port the Node API listens on (Nginx proxies to this).
PORT=5000

# Enables production behaviour (e.g. the JWT_SECRET warning).
NODE_ENV=production

# REQUIRED in production. Use a long random string, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret

# Allowed browser origin(s) for CORS / Socket.io, comma-separated.
# Same-origin deploy (Nginx serves the build + proxies the API) can leave this as *.
# To lock down: CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_ORIGIN=*
