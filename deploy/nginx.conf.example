# Hostinger VPS — Nginx site config for KriCar
# Save as: /etc/nginx/sites-available/kricar  then:
#   sudo ln -s /etc/nginx/sites-available/kricar /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# Replace YOUR_DOMAIN and the dist path. Certbot will add the TLS lines later.

server {
    listen 80;
    server_name YOUR_DOMAIN www.YOUR_DOMAIN;

    # Serve the built React app directly (fast static files)
    root /var/www/kricar/frontend/dist;
    index index.html;

    client_max_body_size 12M;   # allow KYC / car photo uploads

    # API → Node
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Uploaded files (served by Node from backend/uploads)
    location /uploads/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
    }

    # Socket.io (WebSocket upgrade)
    location /socket.io/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400;
    }

    # SPA client-side routing — everything else returns index.html
    location / {
        try_files $uri $uri/ /index.html;
    }
}
